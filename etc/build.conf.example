# build.conf — Build configuration for void-repo
#
# Copy this file to etc/build.conf and edit for your environment:
#   cp etc/build.conf.example etc/build.conf
#
# This file is sourced by scripts (setup.sh, build.sh). Settings here
# override the defaults in each script.

# Upstream void-packages repository to clone during builds
UPSTREAM_REPO="https://github.com/void-linux/void-packages.git"

# Branch to checkout (use "master" for stable, can pin to a specific commit)
UPSTREAM_BRANCH="master"

# Target architecture for package builds
#   x86_64  — native build (requires an x86_64 host)
#   aarch64 — cross-build from x86_64 (see README for bootstrap instructions)
XBPS_TARGET_ARCH="x86_64"

# Parallel build jobs (default: number of CPU cores)
XBPS_MAKEJOBS=4

# Whether to run binary-bootstrap automatically
# Set to "no" if you manage the masterdir yourself
BOOTSTRAP="yes"

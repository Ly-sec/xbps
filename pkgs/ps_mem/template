pkgname=ps_mem
version=3.14
revision=2
build_style=python3-module
hostmakedepends="python3-setuptools"
depends="python3"
short_desc="List processes by memory usage"
maintainer="Ly-sec <void@lysec.dev>"
license="GPL-2.0-only"
homepage="https://github.com/pixelb/ps_mem"
distfiles="https://github.com/pixelb/ps_mem/archive/v${version}.tar.gz"
checksum=ad8bf87f9b9acd9b0b4997445bd99a8eeace4d816b207d56b03c5a83fec00514
python_version="3"

do_install() {
	python3 setup.py install --prefix=/usr --root=${DESTDIR}
	install -Dm644 README.md "${DESTDIR}/usr/share/doc/${pkgname}/README.md"
	install -Dm644 ps_mem.1 "${DESTDIR}/usr/share/man/man1/${pkgname}.1"
}

pkgname=electron40
version=40.10.0
revision=1
archs="x86_64"
short_desc="Cross platform application framework based on web technologies"
maintainer="Ly-sec <void@lysec.dev>"
license="BSD-3-Clause, MIT, Apache-2.0"
homepage="https://electronjs.org"
distfiles="https://github.com/electron/electron/releases/download/v${version}/electron-v${version}-linux-x64.zip"
checksum=35efe7401822e8d2e474e13788a6191362c7494dd1f7ae327b70087e0768a667
hostmakedepends="unzip"
nostrip=yes
noverify=yes

do_extract() {
	mkdir -p "${wrksrc}"
	cd "${wrksrc}"
	unzip -q "${XBPS_SRCDISTDIR}/${pkgname}-${version}/electron-v${version}-linux-x64.zip"
}

do_install() {
	vmkdir "usr/lib/${pkgname}"
	cp -a "${wrksrc}"/* "${DESTDIR}/usr/lib/${pkgname}/"
	chmod 755 "${DESTDIR}/usr/lib/${pkgname}/electron"
	vmkdir "usr/bin"
	ln -sf "../lib/${pkgname}/electron" "${DESTDIR}/usr/bin/${pkgname}"
}

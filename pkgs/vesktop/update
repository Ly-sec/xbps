#!/usr/bin/env bash
set -euo pipefail

PKGDIR="$(cd "$(dirname "$0")" && pwd)"
pkgname=vesktop
current=$(grep -E '^version=' "$PKGDIR/template" | sed 's/version=//' | tr -d '"')

latest=$(curl -sL "https://api.github.com/repos/Vencord/Vesktop/releases/latest" \
  | grep '"tag_name"' | sed 's/.*"v//;s/".*//' | head -1)

if [ -z "$latest" ] || [ "$latest" = "$current" ]; then
  exit 0
fi

url="https://github.com/Vencord/Vesktop/releases/download/v${latest}/vesktop_${latest}_amd64.deb"
checksum=$(curl -sL --max-time 120 "$url" | sha256sum | cut -d' ' -f1)

echo "UPDATE:$pkgname|$current|$latest|$checksum"

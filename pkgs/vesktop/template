pkgname=vesktop
version=1.6.5
revision=1
archs="x86_64"
hostmakedepends="tar xz"
maintainer="Ly-sec <void@lysec.dev>"
short_desc="Vesktop"
homepage="https://github.com/Vencord/Vesktop"
license="GPL-3.0-only"
distfiles="https://github.com/Vencord/Vesktop/releases/download/v${version}/vesktop_${version}_amd64.deb"
checksum=2d4c97abe4810703561d59c63cb12b1926f591fe1fe2bf9e914db66c6cc31cf5

do_extract() {
	ar x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/vesktop_${version}_amd64.deb
	tar xf data.tar.xz -C ${wrksrc}
}

do_install() {
	cp -r "$wrksrc"/usr "$DESTDIR"/
	cp -r "$wrksrc"/opt "$DESTDIR"/
}
